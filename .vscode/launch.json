{
  // IntelliSense を使用して利用可能な属性を学べます。
  // 既存の属性の説明をホバーして表示します。
  // 詳細情報は次を確認してください: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ComRenderer",
      "type": "chrome",
      "request": "attach",
      "port": 9229,
      "webRoot": "${workspaceRoot}"
    },
    {
      "name": "ComMain",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "${workspaceRoot}/node_modules/.bin/electron",
      "attachSimplePort": 9229,
      "windows": {
        "runtimeExecutable": "${workspaceRoot}\\node_modules\\.bin\\electron.ps1"
      },
      "args": [".", "debug", "vscode", "--remote-debugging-port=9229"],
      "outputCapture": "std",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Electron All",
      "configurations": ["ComMain", "ComRenderer"],
      "stopAll": true
    }
  ]
}
